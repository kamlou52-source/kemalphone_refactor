
# Flask secret (change in prod)
SECRET_KEY=change-me-please

# Database path inside container (keep default)
KEMAL_DB=/app/static/database.db

# Stripe (use test keys for dev)
STRIPE_SECRET_KEY=replace-with-your-stripe-test-key
# Optional webhook verification (can leave empty for dev)
STRIPE_WEBHOOK_SECRET=

# Stripe CLI (for stripe-cli service to run)
STRIPE_CLI_API_KEY=replace-with-your-stripe-cli-key
