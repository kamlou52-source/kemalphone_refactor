# --------- Stats ---------
from collections import Counter
@app.route("/stats")
def stats():
    rows = UserInput.query.all()
    models = Counter([r.modele for r in rows])
    problems = Counter([r.problem for r in rows])

    data = {
        "models": models,
        "problems": problems,
        "total": len(rows)
    }
    return render_template("stats.html", stats=data)

# --------- Assistant (README presenter) ---------
@app.route("/assistant")
def assistant():
    return render_template("assistant.html")

@app.route("/api/readme")
def api_readme():
    # streams README lines progressively
    readme_path = os.path.join(app.root_path, "README.md")
    if not os.path.exists(readme_path):
        return jsonify({"lines": []})
    with open(readme_path, "r", encoding="utf-8") as f:
        lines = [line.rstrip("\n") for line in f.readlines()]
    return jsonify({"lines": lines})

@app.route("/api/coach", methods=["POST"])
def api_coach():
    # Lightweight rule-based tips (placeholder for a real LLM backend)
    q = (request.json or {}).get("q","").lower()
    tips = []
    if "flask" in q:
        tips.append("Utilisez des Blueprints pour modulariser votre application Flask.")
    if "sqlite" in q or "sqlalchemy" in q:
        tips.append("Activez l'echo=True de SQLAlchemy en dev pour inspecter les requêtes.")
    if "css" in q or "responsive" in q:
        tips.append("Adoptez une grille flex ou CSS Grid et testez sur 360px/768px/1024px.")
    if not tips:
        tips = ["Précisez votre besoin (ex: Flask, DB, Front, Déploiement, Tests) et j’adapterai les conseils."]
    return jsonify({"answer": " ".join(tips)})


