@app.route('/invoice/<int:invoice_id>/email', methods=['POST'])\n@staff_required\ndef invoice_email(invoice_id):\n    if not mail:\n        flash(_('E-mail non configuré. Veuillez définir Flask-Mail.'), 'error')\n        return redirect(url_for('invoice_view', invoice_id=invoice_id))\n    inv = Invoice.query.get_or_404(invoice_id)\n    items = InvoiceItem.query.filter_by(invoice_id=inv.id).all()\n    pdf = build_invoice_pdf(inv, items)\n    msg = Message(subject=f'Votre facture/devis #{invoice_id}', recipients=[inv.customer_email])\n    msg.body = _('Veuillez trouver ci-joint votre facture/devis.')\n    msg.attach(f'invoice_{invoice_id}.pdf', 'application/pdf', pdf.read())\n    mail.send(msg)\n    flash(_('E-mail envoyé.'), 'success')\n    return redirect(url_for('invoice_view', invoice_id=invoice_id))\n

# ---------- CSV export ----------
import csv
from flask import Response

@app.route('/export/invoices.csv')
@admin_required
def export_invoices_csv():
    si = io.StringIO()
    cw = csv.writer(si)
    cw.writerow(['ID','Nom','Email','Mode','Sous-total','TVA','Total','Statut','Créé'])
    for inv in Invoice.query.all():
        cw.writerow([inv.id, inv.customer_name, inv.customer_email, inv.method, inv.subtotal, inv.vat_amount, inv.total, inv.status, inv.created])
    output = si.getvalue().encode('utf-8')
    return Response(output, mimetype='text/csv', headers={'Content-Disposition':'attachment;filename=invoices.csv'})

@app.route('/export/userinputs.csv')
@admin_required
def export_userinputs_csv():
    si = io.StringIO()
    cw = csv.writer(si)
    cw.writerow(['ID','Prénom','Modèle','Problème','Créé'])
    for u in UserInput.query.all():
        cw.writerow([u.id, u.fname, u.modele, u.problem, u.created])
    output = si.getvalue().encode('utf-8')
    return Response(output, mimetype='text/csv', headers={'Content-Disposition':'attachment;filename=userinputs.csv'})



# ---------- Stripe Checkout integration stub ----------
import stripe
stripe.api_key = os.environ.get('STRIPE_SECRET_KEY','sk_test_xxx')

@app.route('/stripe/checkout/<int:invoice_id>')
@staff_required
def stripe_checkout(invoice_id):
    inv = Invoice.query.get_or_404(invoice_id)
    session = stripe.checkout.Session.create(
        payment_method_types=['card'],
        line_items=[{
            'price_data': {
                'currency': 'chf',
                'product_data': {'name': f'Facture {inv.id}'},
                'unit_amount': int(inv.total*100),
            },
            'quantity': 1,
        }],
        mode='payment',
        success_url=url_for('invoice_view', invoice_id=inv.id, _external=True),
        cancel_url=url_for('invoice_view', invoice_id=inv.id, _external=True),
    )
    return redirect(session.url, code=303)



# ---------- Stripe Checkout Integration ----------
import stripe
app.config.setdefault('STRIPE_SECRET_KEY', os.environ.get('STRIPE_SECRET_KEY', ''))
app.config.setdefault('STRIPE_WEBHOOK_SECRET', os.environ.get('STRIPE_WEBHOOK_SECRET', ''))
stripe.api_key = app.config['STRIPE_SECRET_KEY']

@app.route('/pay/checkout/<int:invoice_id>')
@staff_required
def pay_checkout(invoice_id):
    inv = Invoice.query.get_or_404(invoice_id)
    if not app.config['STRIPE_SECRET_KEY']:
        flash(_('Stripe n\'est pas configuré (STRIPE_SECRET_KEY manquant).'), 'error')
        return redirect(url_for('invoice_view', invoice_id=invoice_id))

    success_url = url_for('invoice_view', invoice_id=invoice_id, _external=True) + "?paid=1"
    cancel_url = url_for('invoice_view', invoice_id=invoice_id, _external=True)

    # Stripe expects amounts in cents (integer)
    amount_cents = int(round(inv.total * 100))

    session = stripe.checkout.Session.create(
        mode='payment',
        payment_method_types=['card'],
        line_items=[{
            'quantity': 1,
            'price_data': {
                'currency': 'chf',
                'product_data': {'name': f"Invoice #{inv.id} - {inv.customer_name}"},
                'unit_amount': amount_cents
            }
        }],
        success_url=success_url,
        cancel_url=cancel_url,
        metadata={'invoice_id': str(inv.id)}
    )
    return redirect(session.url, code=303)

@app.route('/stripe/webhook', methods=['POST'])
def stripe_webhook():
    payload = request.data
    sig_header = request.headers.get('Stripe-Signature')
    webhook_secret = app.config['STRIPE_WEBHOOK_SECRET']
    event = None
    try:
        if webhook_secret:
            event = stripe.Webhook.construct_event(payload=payload, sig_header=sig_header, secret=webhook_secret)
        else:
            event = stripe.Event.construct_from(json.loads(payload), stripe.api_key)
    except Exception as e:
        return str(e), 400

    if event['type'] == 'checkout.session.completed':
        session_obj = event['data']['object']
        invoice_id = session_obj.get('metadata', {}).get('invoice_id')
        if invoice_id:
            inv = Invoice.query.get(int(invoice_id))
            if inv:
                inv.status = 'paid'
                db.session.commit()
    return '', 200


# ---------- Admin Dashboard ----------
@app.route('/admin')
@login_required
@admin_required
def admin_dashboard():
    users = User.query.order_by(User.id.asc()).all()
    invoices = Invoice.query.order_by(Invoice.created.desc()).all()
    userinputs = UserInput.query.order_by(UserInput.created.desc()).all()
    return render_template('admin.html', users=users, invoices=invoices, userinputs=userinputs)

@app.route('/admin/set-role/<int:user_id>', methods=['POST'])
@login_required
@admin_required
def admin_set_role(user_id):
    role = request.form.get('role') or 'user'
    if role not in ('user','staff','admin'):
        flash('Rôle invalide.', 'error')
        return redirect(url_for('admin_dashboard'))
    u = User.query.get_or_404(user_id)
    u.role = role
    db.session.commit()
    flash('Rôle mis à jour.', 'success')
    return redirect(url_for('admin_dashboard'))


# ---------- Demo data loader ----------
@app.route('/admin/load-demo')
@login_required
@admin_required
def admin_load_demo():
    # Create demo users if not existing
    if not User.query.filter_by(email="admin@example.com").first():
        admin = User(email="admin@example.com", role="admin")
        admin.set_password("adminpass")
        db.session.add(admin)
    if not User.query.filter_by(email="staff@example.com").first():
        staff = User(email="staff@example.com", role="staff")
        staff.set_password("staffpass")
        db.session.add(staff)
    if not User.query.filter_by(email="user@example.com").first():
        user = User(email="user@example.com", role="user")
        user.set_password("userpass")
        db.session.add(user)
    db.session.commit()

    # Create demo userinputs
    if not UserInput.query.first():
        ui1 = UserInput(fname="Alice", modele="iPhone 12", problem="Écran cassé")
        ui2 = UserInput(fname="Bob", modele="Samsung S20", problem="Batterie faible")
        db.session.add_all([ui1, ui2])
        db.session.commit()

    # Create demo invoices
    if not Invoice.query.first():
        inv1 = Invoice(customer_name="Charlie", customer_email="charlie@example.com", method="quote",
                      subtotal=200, vat_amount=16.2, total=216.2, status="draft")
        db.session.add(inv1); db.session.flush()
        db.session.add(InvoiceItem(invoice_id=inv1.id, description="Réparation écran", qty=1, unit_price=200, vat_code="standard", vat_rate=0.081))

        inv2 = Invoice(customer_name="Diana", customer_email="diana@example.com", method="pay_now",
                      subtotal=100, vat_amount=2.6, total=102.6, status="paid")
        db.session.add(inv2); db.session.flush()
        db.session.add(InvoiceItem(invoice_id=inv2.id, description="Remplacement batterie", qty=1, unit_price=100, vat_code="reduit", vat_rate=0.026))

        db.session.commit()

    flash("Données de démonstration chargées. Connectez-vous avec admin@example.com / adminpass", "success")
    return redirect(url_for('admin_dashboard'))


# ---------- Seed demo via route (admin only) ----------
@app.route('/admin/seed')
@login_required
@admin_required
def admin_seed():
    # Recrée la base et injecte des données de démonstration
    from datetime import datetime, timedelta
    from random import choice, randint
    db.drop_all()
    db.create_all()

    admin = User(email="admin@example.com"); admin.set_password("Admin#123"); admin.role="admin"
    staff = User(email="staff@example.com"); staff.set_password("Staff#123"); staff.role="staff"
    user  = User(email="user@example.com");  user.set_password("User#123");  user.role="user"
    db.session.add_all([admin, staff, user]); db.session.commit()

    models = ["Android Samsung","Android Pixel","iPhone 14","iPhone 13","iPhone 12","iPhone 11"]
    problems = ["Écran cassé","Batterie faible","Caméra floue","Port de charge","Lent/trop chaud","Ne s'allume plus"]
    for _ in range(20):
        ui = UserInput(fname=choice(["Amine","Sara","Leo","Maya","Noah","Lina","Adam","Emma"]),
                       modele=choice(models),
                       problem=choice(problems))
        ui.created = datetime.utcnow() - timedelta(days=randint(0,30), hours=randint(0,23))
        db.session.add(ui)
    db.session.commit()

    vat_codes = list(SWISS_VAT_RATES.keys())
    for i in range(8):
        inv = Invoice(customer_name=choice(["Société Alpha","Mme Dubois","M. Martin","SARL Beta","Mme Rossi","M. Keller"]),
                      customer_email="client{}@mail.com".format(i+1),
                      method=choice(["quote","pay_now","pay_on_pickup"]),
                      status="draft")
        db.session.add(inv); db.session.flush()
        subtotal = 0.0; vat_amount = 0.0
        for j in range(randint(1,3)):
            qty = randint(1,3)
            price = choice([49.0,79.0,99.0,129.0,149.0,199.0])
            vat_code = choice(vat_codes)
            vat_rate = SWISS_VAT_RATES[vat_code]
            db.session.add(InvoiceItem(invoice_id=inv.id, description=f"Prestation {j+1}", qty=qty, unit_price=price, vat_code=vat_code, vat_rate=vat_rate))
            subtotal += qty*price
            vat_amount += qty*price*vat_rate
        inv.subtotal = round(subtotal,2)
        inv.vat_amount = round(vat_amount,2)
        inv.total = round(inv.subtotal + inv.vat_amount, 2)
        inv.status = choice(["draft","pending","paid"])
        inv.created = datetime.utcnow() - timedelta(days=randint(0,20))
    db.session.commit()

    flash('Base réinitialisée avec des données de démonstration.', 'success')
    return redirect(url_for('admin_dashboard'))

if __name__ == "__main__":
    app.run(debug=True)
